# index.html: nunca cachear — el browser siempre pide la versión fresca
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Assets de Vite (JS/CSS con hash en el nombre): cachear para siempre
# Vite genera nombres como main.a1b2c3d4.js, por eso es seguro
/assets/*
  Cache-Control: public, max-age=31536000, immutable
